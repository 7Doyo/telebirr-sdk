# Telebirr SDK — React (Next.js) Example
# Copy this file to .env.local and fill in your values
#
# Server-side API routes (app/api/) use TELEBIRR_* (no prefix).
# Client-side pages (app/page.tsx) use NEXT_PUBLIC_TELEBIRR_*.

# ── Server-side (API routes) ──────────────────────────────────────────
TELEBIRR_ENVIRONMENT=SANDBOX
TELEBIRR_FABRIC_APP_ID=
TELEBIRR_MERCHANT_APP_ID=
TELEBIRR_MERCHANT_CODE=
TELEBIRR_API_KEY=sk_test_...
TELEBIRR_PRIVATE_KEY=
TELEBIRR_SHORT_CODE=220311
TELEBIRR_TIMEOUT=120m
TELEBIRR_NOTIFY_URL=https://example.com/webhook

# ── Client-side (page.tsx) ────────────────────────────────────────────
NEXT_PUBLIC_TELEBIRR_ENVIRONMENT=SANDBOX
NEXT_PUBLIC_TELEBIRR_FABRIC_APP_ID=
NEXT_PUBLIC_TELEBIRR_MERCHANT_APP_ID=
NEXT_PUBLIC_TELEBIRR_MERCHANT_CODE=
NEXT_PUBLIC_TELEBIRR_API_KEY=
NEXT_PUBLIC_TELEBIRR_SHORT_CODE=220311
