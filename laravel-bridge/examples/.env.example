# Telebirr SDK — Laravel Example
# Copy this file to your project's .env and fill in your values
#
# These values are read by config/telebirr.php via config() helpers.
# php artisan vendor:publish --tag=telebirr-config to expose the config file.

# ── Telebirr Credentials ──────────────────────────────────────────────
TELEBIRR_ENVIRONMENT=SANDBOX
TELEBIRR_FABRIC_APP_ID=
TELEBIRR_MERCHANT_APP_ID=
TELEBIRR_MERCHANT_CODE=
TELEBIRR_API_KEY=sk_test_...
TELEBIRR_PRIVATE_KEY_PATH=
TELEBIRR_SHORT_CODE=220311
TELEBIRR_TIMEOUT=120m
TELEBIRR_NOTIFY_URL=https://yourapp.com/webhooks/telebirr
