# Telebirr SDK — Dart Example
# Copy this file to .env and fill in your values
#
# Note: dart_core does not read .env files by default.
# Pass these values directly to the Config constructor, or use
# a package like envied if you prefer .env loading.

# ── Telebirr Credentials ──────────────────────────────────────────────
TELEBIRR_ENVIRONMENT=SANDBOX
TELEBIRR_FABRIC_APP_ID=
TELEBIRR_MERCHANT_APP_ID=
TELEBIRR_MERCHANT_CODE=
TELEBIRR_API_KEY=sk_test_...
TELEBIRR_PRIVATE_KEY_PATH=./private_key.pem
TELEBIRR_SHORT_CODE=220311
TELEBIRR_TIMEOUT=120m
TELEBIRR_NOTIFY_URL=https://example.com/webhook
